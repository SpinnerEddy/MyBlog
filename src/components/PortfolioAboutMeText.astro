---
import { getEntry, render } from 'astro:content';

const entry = await getEntry('about', 'index');
const { Content } = await render(entry);
---

<div class="flex flex-col items-center text-center gap-4 py-12">
	<img
		src={entry.data.icon}
		alt="myicon"
		class="w-32 h-32 rounded-full"
	/>

	<div class="space-y-10">
		<h1 class="content-title-font text-4xl font-medium tracking-tight leading-none">
			{entry.data.name}
		</h1>

		<div class="max-w-xl text-gray-600 space-y-2">
			<Content />
		</div>
	</div>
</div>
