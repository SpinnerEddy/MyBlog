---
interface Props {
	screenName: string; // 例: "EKey2210"（先頭@なし）
	height?: number;
}
const { screenName, height = 600 } = Astro.props;
---

<div class="x-timeline-container" data-screen-name={screenName} data-height={height} style={`min-height: ${height}px`}>
	<p class="x-timeline-placeholder">読み込み中...</p>
</div>

<script>
	function loadTwttrScript(): Promise<any> {
		return new Promise((resolve) => {
			if ((window as any).twttr?.widgets) {
				resolve((window as any).twttr);
				return;
			}
			const script = document.createElement('script');
			script.src = 'https://platform.x.com/widgets.js';
			script.async = true;
			script.onload = () => resolve((window as any).twttr);
			script.onerror = () => resolve(null);
			document.head.appendChild(script);
		});
	}

	function showFallback(el: HTMLElement, screenName: string) {
		el.innerHTML = '';
		const link = document.createElement('a');
		link.className = 'x-timeline-fallback';
		link.href = `https://x.com/${screenName}`;
		link.target = '_blank';
		link.rel = 'noopener noreferrer';
		link.textContent = `@${screenName} をXで見る`;
		el.appendChild(link);
	}

	const containers = document.querySelectorAll<HTMLElement>('.x-timeline-container');

	const observer = new IntersectionObserver(
		(entries, obs) => {
			for (const entry of entries) {
				if (!entry.isIntersecting) continue;
				const el = entry.target as HTMLElement;
				obs.unobserve(el);

				const screenName = el.dataset.screenName!;
				const height = Number(el.dataset.height ?? 600);

				// X Publish(publish.twitter.com)が生成する公式の静的マークアップと同じ形にする。
				// widgets.jsの自動フルページスキャンに巻き込まれないよう、
				// スクリプト読み込み後にこの要素だけをtwttr.widgets.load()で対象にして変換する。
				const anchor = document.createElement('a');
				anchor.className = 'twitter-timeline';
				anchor.href = `https://x.com/${screenName}?ref_src=twsrc%5Etfw`;
				anchor.setAttribute('data-height', String(height));
				anchor.textContent = `Posts by ${screenName}`;
				el.innerHTML = '';
				el.appendChild(anchor);

				// widgets.jsがブロックされている/APIが失敗した場合に備え、一定時間で埋め込みを諦めてリンクにフォールバックする。
				// iframeが挿入されただけでは成功と判定しない（X側の取得が失敗すると中身が空でiframeだけ挿入されるケースがあるため）。
				// 実際に高さを持ったかどうかで判定する。
				const fallbackTimer = setTimeout(() => {
					const iframe = el.querySelector('iframe');
					const rendered = !!iframe && iframe.getBoundingClientRect().height > 20;
					if (!rendered) showFallback(el, screenName);
				}, 8000);

				loadTwttrScript().then((twttr) => {
					if (!twttr?.widgets) {
						clearTimeout(fallbackTimer);
						showFallback(el, screenName);
						return;
					}
					twttr.widgets.load(el);
				});
			}
		},
		{ rootMargin: '200px' }, // 画面に入る少し手前で先読みしておく
	);

	containers.forEach((el) => observer.observe(el));
</script>

<style>
	.x-timeline-fallback {
		display: block;
		padding: 1em;
		text-align: center;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		color: rgb(var(--accent));
		text-decoration: none;
	}
</style>
